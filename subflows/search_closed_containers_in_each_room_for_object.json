{
  "task": "search closed containers in each room for object",
  "objects": ["${room}", "${container}"],
  "steps": [
    {
      "sid": "look_around",
      "step_type": "action",
      "action": "look around",
      "next_sid": "loop_rooms"
    },
    {
      "sid": "loop_rooms",
      "step_type": "for_loop",
      "iterator": "room",
      "collection": "all_locations",
      "steps": [
        {
          "sid": "enter_room",
          "step_type": "action",
          "action": "go to ${room}",
          "next_sid": "loop_containers"
        },
        {
          "sid": "loop_containers",
          "step_type": "for_loop",
          "iterator": "container",
          "collection": "all_closed_containers",
          "steps": [
            {
              "sid": "open_container",
              "step_type": "action",
              "action": "open ${container}",
              "next_sid": "check_item"
            },
            {
              "sid": "check_item",
              "step_type": "branch",
              "condition": "${object} is available",
              "next_sid_if_true": "found_break",
              "next_sid_if_false": "continue_container"
            },
            {
              "sid": "found_break",
              "step_type": "break"
            },
            {
              "sid": "continue_container",
              "step_type": "action",
              "action": "look around",
              "next_sid": ""
            }
          ],
          "next_sid": "continue_room"
        },
        {
          "sid": "continue_room",
          "step_type": "action",
          "action": "look around",
          "next_sid": ""
        }
      ],
      "next_sid": ""
    }
  ]
}